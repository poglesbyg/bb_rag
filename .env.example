# Copy to .env and fill in what you need. .env is gitignored and loaded
# automatically — no need to `export` anything by hand.

# --- claude (default provider) ---
ANTHROPIC_API_KEY=

# --- huggingface ---
HF_API_TOKEN=

# --- ollama (no token needed, just override if your setup differs) ---
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_GEN_MODEL=llama3.2

# --- huggingface model overrides ---
# HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# HF_GEN_MODEL=HuggingFaceH4/zephyr-7b-beta
